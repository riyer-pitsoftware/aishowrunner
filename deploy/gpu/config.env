#!/usr/bin/env bash
# ChronoCanvas GPU Infrastructure — Shared Configuration
# Sourced by all GPU VM scripts (create, start, stop, status, etc.)
#
# Usage: source config.env (from deploy/gpu/ directory)

# ─── GCP Project ────────────────────────────────────────────
# REQUIRED: Set this before running any script
: "${GCP_PROJECT_ID:?Error: GCP_PROJECT_ID must be set. Run: export GCP_PROJECT_ID=your-project-id}"
GCP_REGION="us-east1"
GCP_ZONE="us-east1-c"

# ─── GCS Buckets ────────────────────────────────────────────
GCS_MODELS_BUCKET="gs://chronocanvas-models"
GCS_OUTPUT_BUCKET="gs://chronocanvas-outputs"

# ─── L4 Tier (Image Generation — FLUX.2 Dev, InfiniteYou, ControlNet) ───
L4_INSTANCE_NAME="cc-gpu-l4"
L4_MACHINE_TYPE="g2-standard-8"
L4_ACCELERATOR="type=nvidia-l4,count=1"
L4_BOOT_DISK_SIZE="200GB"
L4_BOOT_DISK_TYPE="pd-ssd"
L4_PROVISIONING="SPOT"
L4_IDLE_TIMEOUT_MIN=30
L4_HOURLY_RATE="0.34"  # Approximate $/hr for SPOT L4

# ─── A100 Tier (Video Generation — Wan 2.6 14B) ────────────
A100_INSTANCE_NAME="cc-gpu-a100"
A100_MACHINE_TYPE="a2-highgpu-1g"
A100_ACCELERATOR="type=nvidia-tesla-a100,count=1"
A100_BOOT_DISK_SIZE="200GB"
A100_BOOT_DISK_TYPE="pd-ssd"
A100_PROVISIONING="STANDARD"
A100_IDLE_TIMEOUT_MIN=30
A100_HOURLY_RATE="3.67"  # Approximate $/hr for on-demand A100

# NOTE: If A100 40GB VRAM is insufficient for Wan 14B at 720p,
# upgrade to a2-ultragpu-1g (80GB A100). Cost ~$5/hr on-demand.

# ─── Image / Network ───────────────────────────────────────
VM_IMAGE_FAMILY="common-cu129-ubuntu-2204-nvidia-580"
VM_IMAGE_PROJECT="deeplearning-platform-release"
VM_TAGS="gpu-vm"
