# AI Showrunner — Alibaba Cloud ECS deployment env (bead asr-av5.3, TRD §14)
#
# Copy to .env.alibaba and fill in REAL values. NEVER commit the filled file.
#   cp deploy/alibaba/.env.alibaba.example deploy/alibaba/.env.alibaba
#
# deploy.sh sources this file and passes it to docker compose. Two groups:
#   (A) RUNTIME — consumed by the compose stack on the ECS host.
#   (B) DEPLOY  — consumed only by deploy.sh on your workstation (ACR + SSH).

# ════════════════════════════════════════════════════════════════════════
# (A) RUNTIME — read by docker-compose.alibaba.yml
# ════════════════════════════════════════════════════════════════════════

# ── Skill plane: Qwen Cloud via DashScope (OpenAI-compatible) ────────────
# REQUIRED. DashScope key powers the Qwen Cloud text/skill plane and media.
# International (Singapore) account key. The skill plane is flipped to Qwen
# Cloud by HARNESS_MODELS_PATH=/app/.harness/models.cloud.yaml (set in compose).
DASHSCOPE_API_KEY=

# OPTIONAL dedicated Qwen Cloud key; falls back to DASHSCOPE_API_KEY if blank.
QWEN_CLOUD_API_KEY=
QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Continuity eval (critic tier). Leave true; runs on qwen-cloud/qwen-plus.
EVAL_ENABLED=true
EVAL_MODEL=qwen-cloud/qwen-plus

# ── Database (containerized Postgres+pgvector on the ECS host) ───────────
# To use Alibaba RDS for PostgreSQL instead, leave POSTGRES_* as-is for the
# db container OR drop the db service and point DATABASE_URL at RDS in compose.
POSTGRES_USER=chronocanvas
POSTGRES_PASSWORD=            # REQUIRED — strong password (openssl rand -hex 16)
POSTGRES_DB=chronocanvas

# ── Security / access (REQUIRED for a public deployment) ─────────────────
# App refuses to start with the insecure default SECRET_KEY.
SECRET_KEY=                   # REQUIRED — openssl rand -hex 32
APP_PASSWORD=                 # REQUIRED — password gate for the public app
ADMIN_API_KEY=                # OPTIONAL — openssl rand -hex 32 (admin diag endpoints)

# CORS: include the public URL the browser will hit (frontend origin).
# JSON array. Example: ["http://203.0.113.10","https://showrunner.example.com"]
CORS_ORIGINS=["http://localhost"]

# ── Logging / serving ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
HTTP_PORT=80                  # host port the frontend (nginx) binds to

# ── Image tags (also used by deploy.sh build/push) ───────────────────────
# Local builds default to :latest. When pushing to ACR, deploy.sh rewrites
# these to the fully-qualified ACR refs (see ACR_* below).
API_IMAGE=ai-showrunner-api:latest
FRONTEND_IMAGE=ai-showrunner-frontend:latest

# ════════════════════════════════════════════════════════════════════════
# (B) DEPLOY — read by deploy.sh only (workstation side)
# ════════════════════════════════════════════════════════════════════════

# ── Alibaba region ───────────────────────────────────────────────────────
ALIBABA_REGION=ap-southeast-1            # Singapore (matches the intl endpoint)

# ── Alibaba Container Registry (ACR) — OPTIONAL push target ───────────────
# If ACR_REGISTRY is set, deploy.sh tags + pushes images and the ECS host
# pulls them. If unset, deploy.sh builds images ON the ECS host instead
# (simpler for a single-box demo; no registry needed).
#   ACR_REGISTRY example: registry-intl.ap-southeast-1.aliyuncs.com
ACR_REGISTRY=
ACR_NAMESPACE=                            # your ACR namespace, e.g. ai-showrunner
ACR_USERNAME=                             # ACR login username
ACR_PASSWORD=                             # ACR login password / access token

# ── ECS host (SSH target that runs the compose stack) ────────────────────
ECS_HOST=                                 # public IP or DNS of the ECS instance
ECS_SSH_USER=root
ECS_SSH_KEY=~/.ssh/id_rsa                 # path to the private key for ECS_HOST
ECS_SSH_PORT=22
# Remote directory on the ECS host where the repo / compose files live.
ECS_REMOTE_DIR=/opt/ai-showrunner
