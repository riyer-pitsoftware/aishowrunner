# Test-only environment (NON-SECRET, safe to commit). Loaded by
# backend/tests/conftest.py so `pytest` runs with no inline env vars.
# NOT for production — these are deliberately throwaway values.
DATABASE_URL=sqlite+aiosqlite:///:memory:
SECRET_KEY=test-key-not-default-1234567890
DEPLOYMENT_MODE=local
DASHSCOPE_API_KEY=
EVAL_ENABLED=false
